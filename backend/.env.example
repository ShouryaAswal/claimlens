# Copy this file to .env and fill in your real keys.
# .env is gitignored -- it will never be committed or end up in a zip.

# --- LLM providers (Sprint 2/3/4 agents) ---
# Groq: https://console.groq.com  (used for classification, doc-type
# tagging, triage reasoning support, and the reviewer summary)
GROQ_API_KEY=

# Gemini: https://aistudio.google.com/apikey  (used for section extraction
# -- large context window holds the full claim corpus in one call)
GOOGLE_API_KEY=

# Optional model overrides -- defaults already match Groq's post-2026-06-17
# recommended models and a current Gemini Flash release. Only set these if
# you specifically want a different model.
# CLAIMLENS_GROQ_MODEL=openai/gpt-oss-120b
# CLAIMLENS_GEMINI_MODEL=gemini-3-flash

# --- OCR engine (Sprint 1) ---
# "tesseract" (default, no setup) or "paddleocr" (heavier, see
# PADDLEOCR_SETUP.md). Leave unset to use Tesseract.
# CLAIMLENS_OCR_ENGINE=tesseract
